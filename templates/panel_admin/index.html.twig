{% extends 'base.html.twig' %}

{% block title %}Votre tableau de bord administrateur
{% endblock %}

{% block body %}

	{% block admin_layout %}
		{{ include('layout/admin_layout.html.twig')}}
	{% endblock %}

	<h1>Votre tableau de bord administrateur</h1>

	<div
		class="admin-dashboard">

		{# --- SECTION UTILISATEURS --- #}
		<h2>Gestion des utilisateurs.</h2>
		<div class="user-table">
			<ul class="user-list">
				{% for user in users %}
					<li class="user-item">
						<div class="user-item-content">
							<div class="detail-row">
								<span class="detail-label">Pseudo:</span>
								<span class="detail-value">{{ user.pseudo }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Nom:</span>
								<span class="detail-value">{{ user.nom }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Prénom:</span>
								<span class="detail-value">{{ user.prenom }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Email:</span>
								<span class="detail-value">{{ user.email }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Statut:</span>
								<span class="detail-value">
									{% if user.isActive %}
										<span class="status-active">Activé</span>
									{% else %}
										<span class="status-inactive">Désactivé</span>
									{% endif %}
								</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Banni:</span>
								<span class="detail-value">
									{% if user.isBanned %}
										<span class="banned-yes">Oui</span>
									{% else %}
										<span class="banned-no">Non</span>
									{% endif %}
								</span>
							</div>
							{% if is_granted('ROLE_ADMIN') %}
								<div class="detail-row">
									<span class="detail-label">Rôles:</span>
									<span class="detail-value">
										{% for role in user.roles %}
											{% if role == 'ROLE_ADMIN' %}
												Admin
											{% elseif role == 'ROLE_USER' %}
												Utilisateur
											{% else %}
												{{ role }}
											{% endif %}
										{% endfor %}
									</span>
								</div>
							{% endif %}
						</div>

						<div class="user-item-actions">
							{% if user.isBanned == false %}
								<a class="btn-principal" href="{{ path('app_user_ban', {'id': user.id}) }}" onclick="return confirm('Êtes-vous sûr de vouloir bannir l\'utilisateur ?');">Bannir</a>
							{% else %}
								<a class="btn-principal" href="{{ path('app_user_unban', {'id': user.id}) }}" onclick="return confirm('Êtes-vous sûr de vouloir réintégrer l\'utilisateur ?');">Réintégrer</a>
							{% endif %}
							<form action="{{ path('app_admin_user_delete', {'id': user.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur?');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
								<button class="btn-principal" type="submit">Supprimer</button>
							</form>
						</div>
					</li>
				{% endfor %}
			</ul>
			{% if users.pageCount > 1 %}
				<div class="navigation">{{ knp_pagination_render(users) }}</div>
			{% endif %}
		</div>

		{# --- SECTION VISITES --- #}
		<h2>Gestion des visites.</h2>
		<div class="user-table">
			<ul class="visit-list">
				{% for visite in visites %}
					<li class="visit-item">
						<div class="visit-item-content">
							<div class="detail-row">
								<span class="detail-label">Pseudo:</span>
								<span class="detail-value">{{ visite.user.pseudo }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Date visite:</span>
								<span class="detail-value">{{ visite.dateVisite ? visite.dateVisite|date('d/m/Y') : '' }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Statut:</span>
								<span class="detail-value">{{ visite.statut }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Date souhaitée:</span>
								<span class="detail-value">{{ visite.dateResaSouhaite ? visite.dateResaSouhaite|date('d/m/Y') : '' }}</span>
							</div>
						</div>
						<div class="visit-item-actions">
							{% if visite.statut != 'annulée' and visite.statut !='validée' %}
								<form method="post" action="{{ path('app_visite_cancel', {'id': visite.id}) }}" onsubmit="return confirm('Annuler cette visite ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ visite.id) }}">
									<button class="btn-principal">Annuler</button>
								</form>
							{% endif %}
							{% if is_granted('ROLE_ADMIN') and visite.statut == 'en_attente' %}
								<form method="post" action="{{ path('app_visite_validate', {'id': visite.id}) }}">
									<input type="hidden" name="_token" value="{{ csrf_token('validate' ~ visite.id) }}">
									<button class="btn-principal">Valider</button>
								</form>
							{% endif %}
							<a class="btn-principal" href="{{ path('app_visite_show', {'id': visite.id}) }}">Voir</a>
							{% if visite.statut == 'en_attente' %}
								<a class="btn-principal" href="{{ path('app_visite_edit', {'id': visite.id}) }}">Modifier</a>
							{% endif %}
						</div>
					</li>
				{% endfor %}
			</ul>
			{% if visites.pageCount > 1 %}
				<div class="navigation">{{ knp_pagination_render(visites) }}</div>
			{% endif %}
		</div>

		{# --- SECTION RÉSERVATIONS --- #}
		<h2>Gestion des réservations.</h2>
		<div class="user-table">
			<ul class="reservation-list">
				{% for reservation in reservations %}
					<li class="reservation-item">
						<div class="reservation-item-content">
							<div class="detail-row">
								<span class="detail-label">Pseudo:</span>
								<span class="detail-value">{{ reservation.user.pseudo }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Période:</span>
								<span class="detail-value">Du
									{{ reservation.dateResaDebut|date('d/m/Y') }}
									au
									{{ reservation.dateResaFin|date('d/m/Y') }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Dossier:</span>
								<span class="detail-value">{{ reservation.dossierResa }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Statut:</span>
								<span class="detail-value">{{ reservation.statut }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Catégorie:</span>
								<span class="detail-value">{{ reservation.categorie.nom }}</span>
							</div>
						</div>
						<div class="reservation-item-actions">
							<a class="btn-principal" href="{{ path('app_reservation_show', {'id': reservation.id}) }}">Voir</a>

							{% if is_granted('ROLE_ADMIN') %}
								{% if reservation.statut == 'en_attente' %}
									<form method="post" action="{{ path('app_reservation_send_contract', {'id': reservation.id}) }}">
										<input type="hidden" name="_token" value="{{ csrf_token('sendContract' ~ reservation.id) }}">
										<button type="submit" class="btn-principal">Contrat</button>
									</form>
								{% endif %}
								{% if reservation.statut == 'contrat_envoye' %}
									<form method="post" action="{{ path('app_reservation_confirm', {'id': reservation.id}) }}">
										<input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ reservation.id) }}">
										<button type="submit" class="btn-principal">Confirmer</button>
									</form>
								{% endif %}
							{% endif %}

							{% if reservation.statut == 'en_attente' %}
								<a class="btn-principal" href="{{ path('app_reservation_edit', {'id': reservation.id}) }}">Modifier</a>
							{% endif %}
						</div>
					</li>
				{% endfor %}
			</ul>
			{% if reservations.pageCount > 1 %}
				<div class="navigation">{{ knp_pagination_render(reservations) }}</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
