{# templates/contact/ticket.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Ticket Technique | S1 Digital{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 50px auto; padding: 30px; border: 2px solid #005088; border-radius: 12px; font-family: sans-serif; background: #fff;">
    <h1 style="color: #005088; margin-top: 0;">🛠️ Rapport d'anomalie</h1>
    <p style="color: #666;">Ce message sera envoyé directement au support technique <strong>S1 Digital</strong>.</p>

    {# Ajout de l'enctype ici #}
    <form method="post" enctype="multipart/form-data" style="margin-top: 20px;">
        <div style="margin-bottom: 20px;">
            <label style="display: block; margin-bottom: 8px; font-weight: bold;">Description du bug :</label>
            <textarea name="message" required style="width: 100%; height: 120px; padding: 10px; border: 1px solid #ccc; border-radius: 6px; font-size: 1rem;"></textarea>
        </div>

        {# Nouveau champ pour les captures d'écran #}
        <div style="margin-bottom: 20px;">
            <label style="display: block; margin-bottom: 8px; font-weight: bold;">Captures d'écran ou documents (Optionnel) :</label>
            <input type="file" name="attachment" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 6px; background: #f9f9f9;">
            <small style="color: #888; display: block; margin-top: 5px;">Formats acceptés : JPG, PNG, PDF (Max 5Mo)</small>
        </div>

        <button type="submit" style="background-color: #005088; color: white; border: none; padding: 12px 20px; border-radius: 6px; cursor: pointer; font-size: 1rem; font-weight: bold; width: 100%;">
            Envoyer le ticket à S1 Digital
        </button>
    </form>
</div>
{% endblock %}