{% extends 'base.html.twig' %}

{% block title %}Détails Réservation #{{ reservation.dossierResa }}{% endblock %}

{% block body %}
    <h1>Récapitulatif de réservation</h1>

    <div class="user-table">
        <div class="detail-row">
            <span class="detail-label">Client :</span>
            <span class="detail-value">{{ reservation.user.pseudo }}</span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Dossier n° :</span>
            <span class="detail-value"><code>{{ reservation.dossierResa }}</code></span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Période :</span>
            <span class="detail-value">Du {{ reservation.dateResaDebut|date('d/m/Y') }} au {{ reservation.dateResaFin|date('d/m/Y') }}</span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Statut :</span>
            <span class="detail-value">{{ reservation.statut|upper }}</span>
        </div>

        {% if reservation.statut in ['contrat_envoyé', 'confirmée', 'modifiée'] %}
            <div class="detail-row">
                <span class="detail-label">Document :</span>
                <span class="detail-value">
                    <a href="{{ path('app_reservation_contract_show', {'id': reservation.id}) }}" target="_blank" class="text-link">
                        📄 Ouvrir mon Contrat (PDF)
                    </a>
                </span>
            </div>
        {% endif %}

        <div class="detail-row">
            <span class="detail-label">Acompte :</span>
            <span class="detail-value">
                {{ reservation.acompte ? '✅ Reçu' : '⏳ En attente' }}
            </span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Catégorie :</span>
            <span class="detail-value">{{ reservation.categorie.nom }}</span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Options :</span>
            <span class="detail-value">
                {% for option in reservation.options %}
                    {{ option.nom }}{% if not loop.last %}, {% endif %}
                {% else %}
                    Aucune option
                {% endfor %}
            </span>
        </div>
    </div>

    {# ZONE D'ACTIONS #}
    <div class="actions-container" style="text-align: center; margin-top: 30px; display: flex; flex-wrap: wrap; gap: 15px; justify-content: center;">

        {% if reservation.statut == 'en_attente' %}
            <a class="btn-principal" href="{{ path('app_reservation_edit', {'id': reservation.id}) }}">
                Modifier ma demande
            </a>
        {% endif %}

        {% if reservation.statut not in ['annulée', 'validée'] and app.user == reservation.user %}
            <form method="post" action="{{ path('app_reservation_cancel', {'id': reservation.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette réservation ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                <button type="submit" class="btn-principal" style="background-color: #A27883;">Annuler la réservation</button>
            </form>
        {% endif %}

        {% if is_granted('ROLE_ADMIN') and reservation.statut == 'en_attente' %}
            {{ include('reservation/_delete_form.html.twig') }}
        {% endif %}

        <a class="btn-principal" href="{{ is_granted('ROLE_ADMIN') ? path('app_panel_admin') : path('app_reservation_index') }}">
            Retour à la liste
        </a>
    </div>
{% endblock %}