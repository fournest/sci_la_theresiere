{% extends 'base.html.twig' %}

{% block title %}Venez visiter la salle{% endblock %}

{% block body %}
    <h1>Réservez votre visite</h1>

    <div class="user-table"> {# On utilise la même classe pour avoir le cadre blanc et l'ombre #}
        <div style="padding: 10px;">
            {{ include('visite/_form.html.twig') }}
        </div>
    </div>

    <div class="actions-container" style="text-align: center; margin-top: 20px;">
        <a class="btn-principal" href="{{ path('app_visite_index') }}">Retour à la liste</a>
    </div>

    {# Calendrier interactif : section de script JavaScript (Inchangé) #}
    <script>
        const datesVisitesPrises = {{ datesVisitesPrises|json_encode|raw }};
        const reservationRanges = {{ reservationRanges|json_encode|raw }};
        
        document.addEventListener("DOMContentLoaded", function () {
            const disableReservationRanges = function (date) {
                date.setHours(0, 0, 0, 0);
                return reservationRanges.some(range => {
                    const start = new Date(range[0]);
                    const end = new Date(range[1]);
                    start.setHours(0, 0, 0, 0);
                    end.setHours(0, 0, 0, 0);
                    return date.getTime() >= start.getTime() && date.getTime() <= end.getTime();
                })
            }

            flatpickr("#visite_dateVisite", {
                dateFormat: "Y-m-d",
                minDate: "today",
                locale: "fr",
                disable: [...datesVisitesPrises]
            });

            flatpickr("#visite_dateResaSouhaite", {
                dateFormat: "Y-m-d",
                minDate: "today",
                locale: "fr",
                disable: [disableReservationRanges]
            });
        });
    </script>
{% endblock %}