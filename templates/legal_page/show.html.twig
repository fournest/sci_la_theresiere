{% extends 'base.html.twig' %}

{% block title %}
    {{ legal_page.title }}
{% endblock %}

{% block body %}
    <h1>{{ legal_page.title }}</h1>

    <div class="user-table">
        {% if is_granted('ROLE_ADMIN') %}
            <div class="detail-row">
                <span class="detail-label">Slug (URL) :</span>
                <span class="detail-value">/legal/{{ legal_page.slug }}</span>
            </div>
        {% endif %}

        <div class="legal-content-area">
            {{ legal_page.content|raw }}
        </div>
    </div>

    <div class="navigation-links">
        {% if is_granted('ROLE_ADMIN') %}
            <a class="btn-principal" href="{{ path('app_legal_page_index') }}">Retour à la liste</a>
            <a class="btn-principal" href="{{ path('app_legal_page_edit', {'slug': legal_page.slug}) }}">Modifier</a>
            
            <div class="danger-zone">
                {{ include('legal_page/_delete_form.html.twig', {'legal_page' : legal_page}) }}
            </div>
        {% else %}
            <a class="btn-principal" href="{{ path('app_home') }}">Retour à l'accueil</a>
        {% endif %}
    </div>
{% endblock %}