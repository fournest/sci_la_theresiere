{% extends 'panel_admin/index.html.twig' %}

{% block title %}Gestion des Documents Légaux{% endblock %}

{% block body %}
    <h1>Gestion des Documents Légaux</h1>

    <div class="user-table">
        {% if legal_pages is not empty %}
            <ul class="visit-list">
                {% for legal_page in legal_pages %}
                    <li class="visit-item">
                        <div class="visit-item-content">
                            <div class="detail-row">
                                <span class="detail-label">ID :</span>
                                <span class="detail-value">{{ legal_page.id }}</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Titre :</span>
                                <span class="detail-value">{{ legal_page.title }}</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Slug (URL) :</span>
                                <span class="detail-value">/legal/{{ legal_page.slug }}</span>
                            </div>
                        </div>

                        <div class="visit-item-actions">
                            <a href="{{ path('app_legal_page_edit', {'slug': legal_page.slug}) }}" class="btn-principal">Modifier</a>
                            
                            <div class="danger-zone">
                                <form method="post" action="{{ path('app_legal_page_delete', {'slug': legal_page.slug}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce document ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ legal_page.id) }}">
                                    <button type="submit" class="btn-principal">Supprimer</button>
                                </form>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>Aucun document légal trouvé.</p>
        {% endif %}
    </div>

    <div class="navigation-links">
        <a href="{{ path('app_legal_page_new') }}" class="btn-principal">Créer un document</a>
        <a href="{{ path('app_panel_admin') }}" class="btn-principal">Retour au tableau de bord</a>
    </div>
{% endblock %}