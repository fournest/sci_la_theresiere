<footer>
    <div class="footer-content">
        <div class="map-container" style="width: 100%; min-height: 250px;">
            {# 🗺️ Carte Google Maps dynamique et interactive (Générée via les infos de la BDD) #}
            <iframe 
                src="https://maps.google.com/maps?q={{ (societe.adresse ~ ', ' ~ societe.code_postal ~ ' ' ~ societe.ville)|url_encode }}&t=&z=14&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="250" 
                style="border:0; border-radius: 8px;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <div class="footer-contact-info">
            <div class="logo-container">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('img/logo.png') }}" alt="Logo de SCI LA THÉRÈSIÈRE">
                </a>
            </div>
            <p>
                <strong>{{ societe.nom }}</strong><br>
                {{ societe.adresse }}<br>
                {{ societe.code_postal }} {{ societe.ville }}<br>
                Tél : {{ societe.telephone }}<br>
                Email : <a href="mailto:{{ societe.email }}">{{ societe.email }}</a>
            </p>
        </div>

        <nav class="footer-nav-buttons">
            <ul>
                <li><a href="{{ path('app_legal_page_show', {'slug': 'mentions-legales'}) }}">Mentions légales</a></li>
                <li><a href="{{ path('app_legal_page_show', {'slug': 'politique-de-confidentialite'}) }}">Confidentialité</a></li>
                <li><a href="{{ path('app_legal_page_show', {'slug': 'conditions-generales-de-location'}) }}">CGL</a></li>
                <li><a href="{{ path('app_legal_page_show', {'slug': 'politique-de-cookies'}) }}">Cookies</a></li>
                <li><a href="#" id="open_preferences_center" class="cookie-preferences-link">Gérer mes cookies</a></li>
            </ul>
        </nav>
    </div>

    <div class="footer-bottom">
        <p>© {{ "now"|date("Y") }} SCI La Thérésière. Tous droits réservés.</p>
        
        <p class="s1-digital-credits">
            Maintenance & Support : <strong>S1 Digital</strong>
        </p>
        
        <p class="s1-digital-credits">
            <a href="mailto:contact@s1digital.fr" style="color: #005088; text-decoration: none; font-weight: 600; border-bottom: 1px solid #005088;">
                📩 contact@s1digital.fr
            </a>
        </p>
        
        <p class="s1-digital-credits">
            Société en cours de formation
        </p>

        {# Le lien pour tes testeurs (proches) #}
        <div class="s1-digital-credits">
            <a href="{{ path('app_ticket_new') }}" >
                🚀 Envoyer un retour / Ticket
            </a>
        </div>
    </div>
</footer>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const openPreferences = function (e) {
        if (e) e.preventDefault();
        if (typeof cookieconsent !== 'undefined' && typeof cookieconsent.showPreferencesCenter === 'function') {
            cookieconsent.showPreferencesCenter();
        } else {
            console.error("TermsFeed (cookieconsent) n'est pas prêt.");
        }
    };

    // Bouton de gestion
    const manageBtn = document.getElementById('btn-manage-cookies');
    if (manageBtn) manageBtn.addEventListener('click', openPreferences);

    // Lien de préférences
    const preferencesLink = document.getElementById('open_preferences_center');
    if (preferencesLink) preferencesLink.addEventListener('click', openPreferences);
});
</script>