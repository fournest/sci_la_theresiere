{% extends 'base.html.twig' %}

{% block title %}{{ option.nom }}{% endblock %}

{% block body %}
    <h1>Détails de l'option</h1>

    <div class="user-table">
        <div class="detail-row">
            <span class="detail-label">Nom de l'option :</span>
            <span class="detail-value">{{ option.nom }}</span>
        </div>
    </div>

    <div class="form-actions">
        <a class="btn-principal" href="{{ path('app_option_index') }}">Retour à la liste</a>
        
        <a class="btn-principal" href="{{ path('app_option_edit', {'id': option.id}) }}">Modifier</a>

        <div class="danger-zone">
            {{ include('option/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}