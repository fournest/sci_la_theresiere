{% extends 'base.html.twig' %}

{% block title %}Profil de
	{{ user.pseudo }}
{% endblock %}

{% block body %}
	<div
		class="user-table">
		{# On utilise la classe commune pour le cadre blanc #}
		<h1>Informations de mon profil</h1>

		<div class="user-info-header">
			<h2 style="color: #562D59;">
				<strong>{{ user.pseudo }}</strong>
			</h2>
		</div>

		<div class="profile-details">
			<div class="detail-row">
				<span class="detail-label">Nom :</span>
				<span class="detail-value">{{ user.nom }}</span>
			</div>
			<div class="detail-row">
				<span class="detail-label">Prénom :</span>
				<span class="detail-value">{{ user.prenom }}</span>
			</div>
			<div class="detail-row">
				<span class="detail-label">Email :</span>
				<span class="detail-value">{{ user.email }}</span>
			</div>
			{% if is_granted('ROLE_ADMIN') %}
				<div class="detail-row">
					<span class="detail-label">Administration :</span>
					<span class="detail-value">Compte Administrateur</span>
				</div>
			{% endif %}
		</div>

		<div class="actions-container" style="margin: 20px 0; text-align: center;">
			{% if app.user and app.user.id == user.id %}
				<a class="btn-principal" href="{{ path('app_user_edit', {'id': app.user.id}) }}">Modifier mon profil</a>
			{% endif %}
		</div>

		{# --- SECTION VISITES --- #}
		{% if visites is not empty %}
			<hr style="border: 1px solid #f1f1f1; margin: 30px 0;">
			<h2 style="font-family: 'Ovo';">Mes visites</h2>
			<ul class="visit-list" style="padding: 0;">
				{% for visite in visites %}
					<li class="visit-item">
						<div class="visit-item-content">
							<div class="detail-row">
								<span class="detail-label">Date :</span>
								<span class="detail-value">{{ visite.dateVisite ? visite.dateVisite|date('d/m/Y') : 'À définir' }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Statut :</span>
								<span class="detail-value">{{ visite.statut|capitalize }}</span>
							</div>
						</div>
						<div class="visit-item-actions">
							<a class="btn-principal" href="{{ path('app_visite_show', {'id': visite.id}) }}">Détails</a>
						</div>
					</li>
				{% endfor %}
			</ul>
		{% endif %}

		{# --- SECTION RÉSERVATIONS --- #}
		{% if reservations is not empty %}
			<hr style="border: 1px solid #f1f1f1; margin: 30px 0;">
			<h2 style="font-family: 'Ovo';">Mes réservations</h2>
			<ul class="reservation-list" style="padding: 0;">
				{% for reservation in reservations %}
					<li class="reservation-item">
						<div class="reservation-item-content">
							<div class="detail-row">
								<span class="detail-label">Dossier :</span>
								<span class="detail-value">{{ reservation.dossierResa }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Période :</span>
								<span class="detail-value">Du
									{{ reservation.dateResaDebut|date('d/m/Y') }}
									au
									{{ reservation.dateResaFin|date('d/m/Y') }}</span>
							</div>
							<div class="detail-row">
								<span class="detail-label">Statut :</span>
								<span class="detail-value">{{ reservation.statut|capitalize }}</span>
							</div>
						</div>
						<div class="visit-item-actions">
							<a class="btn-principal" href="{{ path('app_reservation_show', {'id': reservation.id}) }}">Voir le dossier</a>
						</div>
					</li>
				{% endfor %}
			</ul>
		{% endif %}

		{# --- SECTION MESSAGES --- #}
		{% if contacts is not empty %}
			<hr style="border: 1px solid #f1f1f1; margin: 30px 0;">
			<h2 style="font-family: 'Ovo';">Mes messages</h2>
			<ul class="message-list" style="padding: 0;">
				{% for contact in contacts %}
					{% if contact.recipient.id == user.id %}
						<li class="visit-item">
							<div class="visit-item-content">
								<div class="detail-row">
									<span class="detail-label">Objet :</span>
									<span class="detail-value">{{ contact.objet }}</span>
								</div>
								<div style="padding: 10px 0; color: #4C6576; font-style: italic;">
									{% set mots = contact.message|split(' ') %}
									{% for mot in mots %}
										{% if "http" in mot %}
											<div style="margin: 10px 0;">
												<a href="{{ mot }}" target="_blank" class="btn-principal" style="font-size: 0.8rem;">
													📄 Ouvrir le contrat
												</a>
											</div>
										{% else %}
											{{ mot }}
										{% endif %}
									{% endfor %}
								</div>
							</div>
						</li>
					{% endif %}
				{% endfor %}
			</ul>
		{% endif %}
	</div>

	<div style="text-align: center; margin-top: 20px;">
		<a class="btn-principal" href="{{ path('app_home') }}">Retour à l'accueil</a>
	</div>
{% endblock %}
