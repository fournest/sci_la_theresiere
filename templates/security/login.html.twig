{% extends 'base.html.twig' %}

{% block title %}Connectez-vous{% endblock %}

{% block body %}
    <h1>Accès à mon espace</h1>

    <div class="user-table">
        <form method="post" class="form-container">

            {% if error %}
                <div class="error-message">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="login-info">
                    Vous êtes connecté(e) en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                    <br>
                    <a class="btn-principal" href="{{ path('app_logout') }}">Déconnexion</a>
                </div>
            {% else %}
                
                <div class="form-group">
                    <label for="username">Votre email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
                </div>

                <div class="form-group">
                    <label for="password">Votre mot de passe</label>
                    <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="form-checkbox">
                    <input type="checkbox" name="_remember_me" id="_remember_me">
                    <label for="_remember_me">Se souvenir de moi</label>
                </div>

                <div class="form-actions">
                    <button class="btn-principal" type="submit">Se connecter</button>
                </div>

            {% endif %}
        </form>
    </div>

    <div class="actions-container">
        <p>Pas encore de compte ? <a href="{{ path('app_register') }}">Inscrivez-vous ici</a></p>
        <a class="btn-principal" href="{{ path('app_home') }}">Retour à l'accueil</a>
    </div>
{% endblock %}